# OpenRouter API Key for Ayurvedic LLM Services
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openrouter/free

# Session-history database (OPTIONAL)
# Leave DATABASE_URL empty/unset to run WITHOUT persistence — predictions still
# succeed, the app just won't record history across restarts.
#
# Async SQLAlchemy URL. For managed Postgres (e.g. Neon) use the asyncpg driver
# and require TLS:
#   postgresql+asyncpg://USER:PASSWORD@HOST/DBNAME?ssl=require
#
# The code detects `sslmode=` / `ssl=require` in the URL and forwards TLS to the
# driver, so the query-string form above is sufficient.
DATABASE_URL=

# Feature toggles
KNOWLEDGE_BASE_ENABLED=true
LLM_SUGGESTIONS_ENABLED=true
IMAGE_ENHANCEMENT_ENABLED=true

# ---------------------------------------------------------------------------
# Runtime (injected by the container/platform, NOT committed)
# ---------------------------------------------------------------------------
# PORT the container listens on (health-checks probe /health here).
PORT=8000

# CORS allow-list for the frontend domain, e.g.:
#   FRONTEND_URL=https://herbalai.example.com
# Leave empty only for local/dev (defaults to "*"). In production set it to the
# frontend domain so the API is not open to every origin.
FRONTEND_URL=

# ---------------------------------------------------------------------------
# Model memory tuning (important on tight-RAM hosts like Render's 512 MiB tier)
# ---------------------------------------------------------------------------
# Eagerly pre-load all models at startup. OFF by default so the server binds its
# port immediately and stays within RAM caps; the first request that needs a
# model loads it lazily. Set to "true" on larger instances for snappier first
# requests.
WARM_UP_MODELS=false
# Max number of classifier models kept resident in memory (LRU). 1 (default)
# keeps RAM bounded; raise on bigger instances to keep more models hot.
MODEL_CACHE_MAX=1
