# OpenRouter API Key for Ayurvedic LLM Services
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openrouter/free

# Session-history database (OPTIONAL)
# Leave DATABASE_URL empty/unset to run WITHOUT persistence — predictions still
# succeed, the app just won't record history across restarts.
#
# Async SQLAlchemy URL. For managed Postgres (e.g. Neon) use the asyncpg driver
# and require TLS:
#   postgresql+asyncpg://USER:PASSWORD@HOST/DBNAME?ssl=require
#
# The code detects `sslmode=` / `ssl=require` in the URL and forwards TLS to the
# driver, so the query-string form above is sufficient.
DATABASE_URL=

# Feature toggles
KNOWLEDGE_BASE_ENABLED=true
LLM_SUGGESTIONS_ENABLED=true
IMAGE_ENHANCEMENT_ENABLED=true
