# OpenRouter API Key for Ayurvedic LLM Services
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openrouter/free

# Session-history database (OPTIONAL)
# Leave DATABASE_URL empty/unset to run WITHOUT persistence — predictions still
# succeed, the app just won't record history across restarts.
#
# Async SQLAlchemy URL. For managed Postgres (e.g. Neon) use the asyncpg driver
# and require TLS:
#   postgresql+asyncpg://USER:PASSWORD@HOST/DBNAME?ssl=require
#
# The code detects `sslmode=` / `ssl=require` in the URL and forwards TLS to the
# driver, so the query-string form above is sufficient.
DATABASE_URL=

# Feature toggles
KNOWLEDGE_BASE_ENABLED=true
LLM_SUGGESTIONS_ENABLED=true
IMAGE_ENHANCEMENT_ENABLED=true

# ---------------------------------------------------------------------------
# AWS / ECS Fargate runtime (injected by the task definition, NOT committed)
# ---------------------------------------------------------------------------
# PORT the container listens on (ALB target group health-checks /health here).
PORT=8000

# CORS allow-list for the CloudFront frontend domain, e.g.:
#   FRONTEND_URL=https://herbalai.example.com
# Leave empty only for local/dev (defaults to "*"). On ECS set it to the
# CloudFront / custom domain so the API is not open to every origin.
FRONTEND_URL=

# In production the two secrets below come from AWS Secrets Manager
# (aws_secretsmanager_secret "herbalai-prod-backend") and are NOT set here:
#   OPENROUTER_API_KEY  -> secretsmanager JSON key
#   DATABASE_URL        -> postgresql+asyncpg://USER:PASS@HOST/DB?ssl=require
# See docs/aws-deployment.md for the full wiring.
