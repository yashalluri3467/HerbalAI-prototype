# Copy to `infra/terraform.tfvars` and fill in. NEVER commit the real file.
#
# Demo mode (no custom domain): leave domain_name / acm_cert_arn / route53_zone_id null.
# The API will be served over HTTP on the ALB's default DNS name.

project_name = "herbalai"
region       = "us-east-1"

# GitHub "owner/repo" — scopes the OIDC trust so only THIS repo can assume the CI role.
github_repo = "your-org/HerbalAI-Prototype"

# --- Optional: custom domain + TLS (recommended for production) ---
# domain_name     = "example.com"
# acm_cert_arn   = "arn:aws:acm:us-east-1:123456789012:certificate/xxxx"
# route53_zone_id = "ZXXXXXXXXXXXXX"
# The ACM cert MUST be in us-east-1 and cover both example.com (CloudFront)
# and api.example.com (ALB) — issue one cert with those SANs.

# --- RDS / Fargate sizing (cost levers) ---
db_instance_class = "db.t3.micro"
db_allocated_storage = 20
fargate_cpu    = 2048
fargate_memory = 4096
desired_count  = 2
max_count      = 6
