# Used by `vite build` in production mode (CI runs `npm run build`,
# which uses mode "production" by default, so this file is picked up).
# In CI the VITE_API_BASE_URL GitHub Variable OVERRIDES this file, so set
# it there. Locally, set it before building for prod:
#   https://api.example.com   (custom domain)
#   http://<alb-dns-name>     (demo mode, no domain)
VITE_API_BASE_URL=https://api.example.com
