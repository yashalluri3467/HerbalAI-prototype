# Base URL of the deployed HerbalAI backend (Render).
# Vite inlines this at BUILD time, so it must be set in the Vercel project's
# Environment Variables (at least for Production), not just locally.
#
# Set this in the Vercel dashboard:
#   Project → Settings → Environment Variables
#   Name:  VITE_API_BASE_URL
#   Value: https://herbalai-backend.onrender.com
#
# No trailing slash is needed; src/utils/api.js strips it.
VITE_API_BASE_URL=https://herbalai-backend.onrender.com
