# Base URL of the deployed HerbalAI backend.
# Vite inlines this at BUILD time, so it must be set as the CI Variable
# VITE_API_BASE_URL (which overrides this file) or in a .env.production file —
# not just locally.
#
# On AWS the backend lives behind the ALB / custom domain:
#   - Custom domain:  https://api.example.com
#   - Demo (no domain): http://<alb-dns-name>   (from `terraform output alb_dns_name`)
#
# No trailing slash is needed; src/utils/api.js strips it.
# See docs/aws-deployment.md for the full wiring.
VITE_API_BASE_URL=https://api.example.com
